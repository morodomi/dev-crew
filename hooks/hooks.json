{
  "$schema": "https://json.schemastore.org/claude-code-hooks.json",
  "hooks": {
    "PreCommit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/check-cycle-doc.sh"
          },
          {
            "type": "command",
            "command": "bash tests/test-agents-structure.sh"
          },
          {
            "type": "command",
            "command": "bash scripts/hooks/check-claude-md-staleness.sh"
          }
        ]
      }
    ]
  }
}
